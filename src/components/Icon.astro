---
import { icon } from '../icons';

interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
---

<span class:list={['icon', className]} set:html={icon(name, size, strokeWidth)} />
