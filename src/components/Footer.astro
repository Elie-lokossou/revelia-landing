---
import copy from '../content/copy.fr.json';
import LogoIcon from './LogoIcon.astro';

const { footer } = copy;
---

<footer class="footer">
  <div class="footer__wordmark" aria-hidden="true">
    <span class="footer__wordmark-text">{copy.header.logo}</span>
  </div>

  <div class="container footer__inner">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/#accueil" class="footer__logo">
          <LogoIcon size={24} class="footer__logo-icon" />
          <span class="footer__logo-name">{copy.header.logo}</span>
        </a>
        <p class="footer__tagline">{footer.tagline}</p>
        <p class="footer__description">{footer.description}</p>
        <ul class="footer__social">
          {
            footer.social.map((link) => (
              <li>
                <a href={link.href} aria-label={link.label} class="footer__social-link">
                  {
                    link.label === 'Instagram' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                      </svg>
                    )
                  }
                  {
                    link.label === 'LinkedIn' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                        <rect x="2" y="9" width="4" height="12" />
                        <circle cx="4" cy="4" r="2" />
                      </svg>
                    )
                  }
                  {
                    link.label === 'Facebook' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                      </svg>
                    )
                  }
                </a>
              </li>
            ))
          }
        </ul>
        <a href="#contact" class="footer__cta">{footer.cta}</a>
      </div>

      <nav class="footer__col" aria-label="Navigation">
        <p class="footer__col-title">{footer.quickLinks.title}</p>
        <ul class="footer__col-list">
          {
            footer.quickLinks.items.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))
          }
        </ul>
      </nav>

      <nav class="footer__col" aria-label="Accompagnements">
        <p class="footer__col-title">{footer.services.title}</p>
        <ul class="footer__col-list">
          {
            footer.services.items.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))
          }
        </ul>
      </nav>

      <nav class="footer__col footer__col--legal" aria-label="Informations légales">
        <p class="footer__col-title">{footer.legal.title}</p>
        <ul class="footer__col-list">
          {
            footer.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">{footer.copyright}</p>
    </div>
  </div>
</footer>
