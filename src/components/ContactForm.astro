---
import copy from '../content/copy.fr.json';
import Icon from './Icon.astro';

const { contact } = copy;
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const isDemoMode = !web3Key || web3Key === 'demo-key-replace-me';
const accessKey = isDemoMode ? 'demo-key-replace-me' : web3Key;

const benefitIconNames = ['star', 'shield', 'clock'];
---

<section class="section section--alt section--contact" id="contact">
  <div class="contact__bg" aria-hidden="true"></div>
  <div class="container">
    <div class="reveal section-header section-header--center">
      <p class="section__label">{contact.label}</p>
      <h2 class="section__title">{contact.title}</h2>
      <p class="section__subtitle section__subtitle--center">{contact.subtitle}</p>
    </div>

    <div class="contact-grid reveal-stagger">
      <ul class="contact-benefits">
        {
          contact.benefits.map((benefit, i) => (
            <li class="contact-benefit">
              <Icon name={benefitIconNames[i] ?? 'star'} size={20} class="contact-benefit__icon" />
              <div>
                <p class="contact-benefit__title">{benefit.title}</p>
                <p class="contact-benefit__text">{benefit.text}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="contact-form-card">
        {isDemoMode && (
          <p class="contact-form__demo-notice" role="status">
            {contact.form.demoNotice}
          </p>
        )}

        <div class="contact-form__steps">
          <div class="contact-form__step-bar">
            <div class="contact-form__step-fill" data-step-fill style="width: 33%"></div>
          </div>
          <p class="contact-form__step-label" data-step-label>Étape 1/3 — {contact.steps[0].title}</p>
        </div>

        <form class="contact-form" id="contact-form" novalidate>
          <input type="hidden" name="access_key" value={accessKey} />
          <input type="hidden" name="subject" value="Nouvelle demande — Revelia" />
          <input type="hidden" name="objectif" id="objectif-hidden" value="" />
          <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />

          <!-- Step 1 -->
          <div class="contact-form__panel" data-form-step="1">
            <h3 class="contact-form__panel-title">{contact.steps[0].subtitle}</h3>
            <fieldset class="contact-form__objectives">
              <legend class="visually-hidden">Choisis ton objectif</legend>
              {
                contact.objectives.map((obj) => (
                  <label class="objective-card">
                    <input type="radio" name="objectif_choice" value={obj.label} required />
                    <span class="objective-card__text">{obj.label}</span>
                  </label>
                ))
              }
            </fieldset>
            <button type="button" class="btn btn--red btn--pill btn--full" data-form-next>
              {contact.form.next}
            </button>
          </div>

          <!-- Step 2 -->
          <div class="contact-form__panel" data-form-step="2" hidden>
            <h3 class="contact-form__panel-title">{contact.steps[1].subtitle}</h3>
            <div class="form-group">
              <label for="name">{contact.form.name}</label>
              <input type="text" id="name" name="name" required autocomplete="given-name" />
            </div>
            <div class="form-group">
              <label for="email">{contact.form.email}</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
            <div class="contact-form__nav">
              <button type="button" class="btn btn--ghost btn--pill" data-form-back>{contact.form.back}</button>
              <button type="button" class="btn btn--red btn--pill" data-form-next>{contact.form.next}</button>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="contact-form__panel" data-form-step="3" hidden>
            <h3 class="contact-form__panel-title">{contact.steps[2].subtitle}</h3>
            <div class="form-group">
              <label for="message">{contact.form.message}</label>
              <textarea id="message" name="message" rows="4"></textarea>
            </div>
            <div class="contact-form__nav">
              <button type="button" class="btn btn--ghost btn--pill" data-form-back>{contact.form.back}</button>
              <button type="submit" class="btn btn--red btn--pill" id="submit-btn" data-label={contact.form.submit}>
                {contact.form.submit}
              </button>
            </div>
          </div>

          <p class="contact-form__footnote">{contact.form.footnote}</p>

          <p class="form-message form-message--success" id="form-success" role="status">
            {isDemoMode ? contact.form.demoSuccess : contact.form.success}
          </p>
          <p class="form-message form-message--error" id="form-error" role="alert">
            {contact.form.error}
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ submitLabel: contact.form.submit, isDemoMode, stepTitles: contact.steps.map(s => s.title) }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const stepFill = document.querySelector('[data-step-fill]');
  const stepLabel = document.querySelector('[data-step-label]');
  const objectifHidden = document.getElementById('objectif-hidden');
  const panels = form?.querySelectorAll('[data-form-step]');
  let currentStep = 1;

  function showStep(step) {
    currentStep = step;
    panels?.forEach((p) => {
      const n = Number(p.getAttribute('data-form-step'));
      (p as HTMLElement).hidden = n !== step;
    });
    if (stepFill) (stepFill as HTMLElement).style.width = `${(step / 3) * 100}%`;
    if (stepLabel) stepLabel.textContent = `Étape ${step}/3 — ${stepTitles[step - 1]}`;
  }

  form?.querySelectorAll('[data-form-next]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (currentStep === 1) {
        const selected = form.querySelector('[name="objectif_choice"]:checked');
        if (!selected) {
          form.querySelector('[name="objectif_choice"]')?.closest('.objective-card')?.classList.add('objective-card--error');
          return;
        }
        if (objectifHidden) objectifHidden.value = (selected as HTMLInputElement).value;
      }
      if (currentStep === 2) {
        const name = form.querySelector('#name') as HTMLInputElement;
        const email = form.querySelector('#email') as HTMLInputElement;
        if (!name?.value.trim() || !email?.value.trim() || !email.checkValidity()) {
          name?.reportValidity();
          email?.reportValidity();
          return;
        }
      }
      if (currentStep < 3) showStep(currentStep + 1);
    });
  });

  form?.querySelectorAll('[data-form-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) showStep(currentStep - 1);
    });
  });

  const accessKey = form?.querySelector('[name="access_key"]')?.value;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successEl?.classList.remove('form-message--success');
    errorEl?.classList.remove('form-message--error');

    if (isDemoMode || accessKey === 'demo-key-replace-me') {
      successEl?.classList.add('form-message--success');
      form.reset();
      showStep(1);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.setAttribute('aria-busy', 'true');
    submitBtn.textContent = 'Envoi en cours…';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await response.json();

      if (data.success) {
        successEl?.classList.add('form-message--success');
        form.reset();
        showStep(1);
      } else {
        errorEl?.classList.add('form-message--error');
      }
    } catch {
      errorEl?.classList.add('form-message--error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.removeAttribute('aria-busy');
      submitBtn.textContent = submitBtn.dataset.label ?? 'Envoyer ma demande';
    }
  });
</script>
