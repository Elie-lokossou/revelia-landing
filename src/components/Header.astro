---
import copy from '../content/copy.fr.json';
import LogoIcon from './LogoIcon.astro';

const { header } = copy;
---

<header class="header">
  <div class="container header__inner">
    <a href="/#accueil" class="header__logo">
      <LogoIcon size={20} class="header__logo-icon" />
      <span>{header.logo}</span>
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      {
        header.nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))
      }
    </nav>

    <div class="header__actions">
      <a href="#contact" class="btn btn--red btn--pill header__cta">{header.cta}</a>
      <button
        class="header__burger"
        type="button"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
        id="menu-toggle"
      >
        <span class="header__burger-line" aria-hidden="true"></span>
        <span class="header__burger-line" aria-hidden="true"></span>
        <span class="header__burger-line" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav-backdrop" id="mobile-nav-backdrop" hidden aria-hidden="true"></div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <div class="container mobile-nav__wrap">
      <nav
        class="mobile-nav__panel"
        id="mobile-nav-panel"
        aria-label="Navigation mobile"
      >
        <ul class="mobile-nav__list" role="list">
          {
            header.nav.map((item) => (
              <li>
                <a href={item.href} class="mobile-nav__link">{item.label}</a>
              </li>
            ))
          }
        </ul>
        <div class="mobile-nav__cta">
          <a href="#contact" class="btn btn--red btn--pill mobile-nav__cta-btn">{header.cta}</a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const backdrop = document.getElementById('mobile-nav-backdrop');
  const panel = document.getElementById('mobile-nav-panel');
  const links = mobileNav?.querySelectorAll('.mobile-nav__link, .mobile-nav__cta-btn');

  function isOpen() {
    return toggle?.getAttribute('aria-expanded') === 'true';
  }

  function openMenu() {
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Fermer le menu');
    mobileNav?.removeAttribute('hidden');
    backdrop?.removeAttribute('hidden');
    requestAnimationFrame(() => {
      mobileNav?.classList.add('is-open');
      backdrop?.classList.add('is-visible');
    });
    links?.[0]?.focus();
  }

  function closeMenu() {
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Ouvrir le menu');
    mobileNav?.classList.remove('is-open');
    backdrop?.classList.remove('is-visible');

    const hideAfterClose = () => {
      mobileNav?.setAttribute('hidden', '');
      backdrop?.setAttribute('hidden', '');
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      hideAfterClose();
      return;
    }

    const fallback = window.setTimeout(hideAfterClose, 320);
    const onEnd = (e: TransitionEvent) => {
      if (e.target !== mobileNav || e.propertyName !== 'opacity') return;
      window.clearTimeout(fallback);
      hideAfterClose();
      mobileNav?.removeEventListener('transitionend', onEnd);
    };
    mobileNav?.addEventListener('transitionend', onEnd);
  }

  toggle?.addEventListener('click', () => {
    isOpen() ? closeMenu() : openMenu();
  });

  backdrop?.addEventListener('click', closeMenu);

  links?.forEach((link) => link.addEventListener('click', closeMenu));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen()) {
      closeMenu();
      toggle?.focus();
      return;
    }

    if (e.key !== 'Tab' || !isOpen() || !panel) return;

    const focusables = panel.querySelectorAll<HTMLElement>('a, button');
    if (focusables.length === 0) return;

    const first = focusables[0];
    const last = focusables[focusables.length - 1];

    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
