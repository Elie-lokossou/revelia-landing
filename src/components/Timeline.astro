---
import copy from '../content/copy.fr.json';

const { timeline } = copy;
---

<section class="section section--timeline" id="transformation">
  <div class="timeline__bg" aria-hidden="true"></div>
  <div class="container">
    <div class="reveal section-header section-header--center">
      <p class="section__label">{timeline.label}</p>
      <h2 class="section__title">{timeline.title}</h2>
      <p class="section__subtitle section__subtitle--center">{timeline.subtitle}</p>
    </div>

    <div class="timeline reveal-stagger">
      {
        timeline.weeks.map((week, i) => (
          <article class="timeline__item">
            <div class="timeline__marker">
              <span class="timeline__dot"></span>
              {i < timeline.weeks.length - 1 && <span class="timeline__line" aria-hidden="true"></span>}
            </div>
            <div class="timeline__content">
              <span class="timeline__week">{week.week}</span>
              <h3 class="timeline__title">{week.title}</h3>
              <p class="timeline__text">{week.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
